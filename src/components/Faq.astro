---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  faqs?: FaqItem[];
}

const defaultFaqs: FaqItem[] = [
  {
    question: '¿Atienden todos los días?',
    answer: 'La playa de combustibles atiende las 24 horas, todos los días del año. La tienda Full abre de 06:00 a 22:00 hs. La administración atiende de 08:00 a 12:00 y de 15:00 a 19:00 hs.',
  },
  {
    question: '¿Cuentan con tienda Full?',
    answer: 'Sí, contamos con tienda Full donde vas a encontrar café, comidas rápidas, bebidas y snacks en un ambiente moderno y cómodo.',
  },
  {
    question: '¿Aceptan tarjetas y transferencias?',
    answer: 'Sí, aceptamos tarjetas de débito y crédito, transferencias y los principales medios de pago electrónicos. También podés abonar y acumular beneficios a través de la App YPF.',
  },
  {
    question: '¿Hay beneficios para socios ACA?',
    answer: 'Sí, al ser concesionario oficial YPF ACA, los socios del Automóvil Club Argentino acceden a descuentos y beneficios exclusivos.',
  },
  {
    question: '¿Dónde están ubicados?',
    answer: 'Estamos en Ingeniero Juárez, Formosa. Podés ver la ubicación exacta y cómo llegar en la sección de Ubicación.',
  },
];

const {
  eyebrow = 'Preguntas frecuentes',
  title = '¿Tenés dudas? Te ayudamos',
  subtitle = 'Estas son las consultas más comunes de quienes pasan por Díaz Servicios SRL.',
  faqs = defaultFaqs,
} = Astro.props;
---

<section class="section-light faq">
  <div class="container faq__container">
    <div class="section-header reveal">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>

    <div class="faq__list reveal reveal-delay-1">
      {faqs.map((faq, i) => (
        <div class="faq__item">
          <button
            class="faq__summary"
            type="button"
            aria-expanded="false"
            aria-controls={`faq-body-${i}`}
          >
            {faq.question}
            <span class="faq__icon" aria-hidden="true"></span>
          </button>
          <div class="faq__body" id={`faq-body-${i}`}>
            <p>{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__container {
    max-width: 800px;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq__item {
    background-color: var(--color-gray-light);
    border-radius: var(--radius-md);
    padding: 0.4rem 1.5rem;
    transition: background-color 0.25s ease, box-shadow 0.25s ease;
  }

  .faq__item.is-open {
    background-color: var(--color-white);
    box-shadow: var(--shadow-soft);
  }

  .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding-block: 1.1rem;
    font-size: 1rem;
    font-weight: 700;
    font-family: inherit;
    color: var(--color-aca-blue-dark);
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
  }

  .faq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
  }

  .faq__icon::before,
  .faq__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background-color: var(--color-aca-blue);
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease;
  }

  .faq__icon::before {
    width: 14px;
    height: 2px;
  }

  .faq__icon::after {
    width: 2px;
    height: 14px;
  }

  .faq__item.is-open .faq__icon::after {
    transform: translate(-50%, -50%) rotate(90deg) scaleY(0);
  }

  .faq__body {
    overflow: hidden;
    height: 0;
    transition: height 0.32s ease;
  }

  .faq__body p {
    color: var(--color-gray);
    padding-bottom: 1.25rem;
    font-size: 0.95rem;
  }
</style>

<script>
  function initFaq() {
    document.querySelectorAll<HTMLElement>('.faq__item:not([data-faq-init])').forEach((item) => {
      item.dataset.faqInit = '1';
      const btn = item.querySelector<HTMLButtonElement>('.faq__summary');
      const body = item.querySelector<HTMLElement>('.faq__body');
      if (!btn || !body) return;

      btn.addEventListener('click', () => {
        if (item.classList.contains('is-open')) {
          // CERRAR: fijar altura actual → animar a 0
          body.style.height = body.scrollHeight + 'px';
          body.offsetHeight; // forzar reflow
          requestAnimationFrame(() => { body.style.height = '0px'; });

          item.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');

          let done = false;
          const finish = () => { if (!done) { done = true; body.style.height = ''; } };
          body.addEventListener('transitionend', finish, { once: true });
          setTimeout(finish, 400);
        } else {
          // ABRIR: medir altura natural → animar desde 0
          const target = body.scrollHeight;
          body.style.height = '0px';
          body.offsetHeight; // forzar reflow
          requestAnimationFrame(() => { body.style.height = target + 'px'; });

          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');

          let done = false;
          const finish = () => { if (!done) { done = true; body.style.height = 'auto'; } };
          body.addEventListener('transitionend', finish, { once: true });
          setTimeout(finish, 400);
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initFaq);
</script>
