---
import { WHATSAPP_URL } from "../lib/constants";

const year = new Date().getFullYear();

const quickLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "Servicios", href: "#servicios" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Full", href: "#full" },
  { label: "Ubicación", href: "#ubicacion" },
];

const socials = [
  { label: "Instagram", href: "https://www.instagram.com/aca.ing.juarez/", icon: "instagram" },
  { label: "WhatsApp", href: WHATSAPP_URL("Hola, quiero más información."), icon: "whatsapp" },
];

const icons: Record<string, string> = {
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.5"/><circle cx="17.2" cy="6.8" r="1"/>',
  whatsapp:
    '<path d="M12 3a9 9 0 0 0-7.8 13.4L3 21l4.7-1.2A9 9 0 1 0 12 3Z"/><path d="M8.5 9.3c.2-.5.6-.8 1-.8h.6c.3 0 .5.2.6.5l.6 1.6c.1.3 0 .6-.2.8l-.6.6c.5 1 1.4 1.9 2.4 2.4l.6-.6c.2-.2.5-.3.8-.2l1.6.6c.3.1.5.3.5.6v.6c0 .4-.3.8-.8 1-1.9.7-4.6-.4-6.3-2.1-1.7-1.7-2.8-4.4-2.1-6.3Z"/>',
};
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <div class="footer__brand-name">
        <span class="footer__brand-mark" aria-hidden="true">DS</span>
        <div>
          <strong>Díaz Servicios SRL</strong>
          <p>Concesionario oficial YPF ACA</p>
        </div>
      </div>
      <p class="footer__description">
        Combustibles YPF, beneficios ACA y tienda Full en Ingeniero Juárez,
        Formosa. Tu parada de confianza para seguir viaje.
      </p>
      <div class="footer__badges">
        <span class="badge badge-ypf">YPF</span>
        <span class="badge badge-aca">ACA</span>
        <span class="badge badge-full">Full</span>
      </div>
    </div>

    <div class="footer__col">
      <h3>Links rápidos</h3>
      <ul>
        {
          quickLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer__col">
      <h3>Contacto</h3>
      <ul class="footer__contact">
        <li>📍 RN 81 Km 484, Ing. Guillermo N. Juárez, Formosa</li>
        <li>📞 +54 9 3704247241</li>
        <li>✉️ diazserviciossrl21@gmail.com</li>
      </ul>
    </div>

    <div class="footer__col">
      <h3>Seguinos</h3>
      <div class="footer__socials">
        {
          socials.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              class="footer__social"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                set:html={icons[social.icon]}
              />
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {year} Díaz Servicios SRL. Todos los derechos reservados.</p>
      <p>
        Concesionario oficial YPF ACA · Ingeniero Juárez, Formosa, Argentina
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-aca-blue-dark);
    color: rgba(255, 255, 255, 0.85);
    padding-top: clamp(3rem, 6vw, 5rem);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  .footer__brand-name {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .footer__brand-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--color-ypf-yellow);
    font-weight: 800;
    flex-shrink: 0;
  }

  .footer__brand-name strong {
    display: block;
    color: var(--color-white);
    font-size: 1.05rem;
  }

  .footer__brand-name p {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__description {
    font-size: 0.92rem;
    margin-bottom: 1.25rem;
    max-width: 320px;
  }

  .footer__badges {
    display: flex;
    gap: 0.5rem;
  }

  .footer__col h3 {
    color: var(--color-white);
    font-size: 1rem;
    margin-bottom: 1.1rem;
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-size: 0.92rem;
  }

  .footer__col a {
    transition: color 0.2s ease;
  }

  .footer__col a:hover {
    color: var(--color-ypf-yellow);
  }

  .footer__contact li {
    font-size: 0.92rem;
  }

  .footer__socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.08);
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .footer__social svg {
    width: 18px;
    height: 18px;
  }

  .footer__social:hover {
    background-color: var(--color-ypf-yellow);
    color: var(--color-aca-blue-dark);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: 1.5rem;
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
  }

  @media (min-width: 720px) {
    .footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
    }
  }

  @media (min-width: 720px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
