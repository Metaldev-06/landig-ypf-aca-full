---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero-image.jpg';
---

<section id="inicio" class="hero">
  <div class="hero__media" aria-hidden="true">
    <Image
      src={heroImg}
      alt=""
      class="hero__image"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <h1 class="hero__title reveal reveal-delay-1">
      Tu parada segura en Ingeniero Juárez
    </h1>

    <p class="hero__subtitle reveal reveal-delay-2">
      Estación YPF, beneficios ACA y todo lo que necesitás para seguir viaje,
      con la atención cercana de siempre.
    </p>

    <div class="hero__actions reveal reveal-delay-3">
      <a href="/ubicacion" class="btn btn-primary">Cómo llegar</a>
      <a href="/servicios" class="btn btn-secondary"
        >Conocé nuestros servicios</a
      >
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--header-height) + 2.5rem);
    padding-bottom: 3.5rem;
    overflow: hidden;
    color: var(--color-white);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      135deg,
      var(--color-aca-blue) 0%,
      var(--color-aca-blue-dark) 60%,
      var(--color-black) 100%
    );
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
    mix-blend-mode: luminosity;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(7, 51, 94, 0.55) 0%,
      rgba(7, 51, 94, 0.85) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }
  .hero__title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    margin-bottom: 1.1rem;
  }
  .hero__subtitle {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 540px;
    margin-bottom: 2.25rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }
</style>
