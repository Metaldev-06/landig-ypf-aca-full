---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<section class="page-intro">
  <div class="container page-intro__inner reveal">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1 class="page-intro__title">{title}</h1>
    {subtitle && <p class="page-intro__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .page-intro {
    background: linear-gradient(135deg, var(--color-aca-blue) 0%, var(--color-aca-blue-dark) 100%);
    color: var(--color-white);
    padding-top: calc(var(--header-height) + clamp(2.5rem, 6vw, 4rem));
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }

  .page-intro__inner {
    max-width: 760px;
    margin-inline: auto;
  }

  .page-intro .eyebrow {
    color: var(--color-ypf-yellow);
  }

  .page-intro__title {
    font-size: clamp(2.1rem, 5vw, 3.25rem);
    margin-bottom: 0.85rem;
  }

  .page-intro__subtitle {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
  }
</style>
