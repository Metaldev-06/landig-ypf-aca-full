---
const services = [
  { title: 'Nafta y diésel', icon: '⛽' },
  { title: 'Lubricantes', icon: '🛢️' },
  { title: 'Tienda Full', icon: '🛍️' },
  { title: 'Baños', icon: '🚻' },
  { title: 'Estacionamiento', icon: '🅿️' },
  { title: 'Atención a viajeros', icon: '🧳' },
  { title: 'Beneficios ACA', icon: '🎫' },
  { title: 'Medios de pago', icon: '💳' },
];
---

<section id="servicios" class="section-light services">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Todo en un solo lugar</span>
      <h2 class="section-title">Servicios pensados para tu viaje</h2>
      <p class="section-subtitle">
        Desde la carga de combustible hasta un café caliente: en Díaz
        Servicios encontrás todo lo que necesitás para seguir camino.
      </p>
    </div>

    <div class="grid grid-4 services__grid">
      {services.map((service, index) => (
        <div class={`services__item reveal reveal-delay-${(index % 4) + 1}`}>
          <span class="services__icon" aria-hidden="true">{service.icon}</span>
          <span class="services__title">{service.title}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services__grid {
    gap: 1.1rem;
  }

  .services__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 1.75rem 1.25rem;
    background-color: var(--color-gray-light);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }

  .services__item:hover {
    transform: translateY(-4px);
    border-color: var(--color-ypf-yellow);
    background-color: var(--color-white);
    box-shadow: var(--shadow-soft);
  }

  .services__icon {
    font-size: 2rem;
  }

  .services__title {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-aca-blue-dark);
  }
</style>
