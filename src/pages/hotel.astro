---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { HOTEL_WHATSAPP_NUMBER } from "../lib/constants";

const carouselSlides = [
  { src: "/images/fachada-ypf.jpg", alt: "Vista exterior del hotel" },
  { src: "/images/hotel-1.jpg", alt: "Habitación matrimonial" },
  { src: "/images/hotel-2.jpg", alt: "Habitación doble" },
];

const features = [
  { icon: "🛏️", label: "Habitaciones confortables" },
  { icon: "🅿️", label: "Estacionamiento gratuito" },
  { icon: "☕", label: "Desayuno disponible" },
  { icon: "❄️", label: "Aire acondicionado" },
  { icon: "🎫", label: "Descuento para socios ACA" },
  { icon: "🛣️", label: "Ideal para viajeros en ruta" },
];
---

<Layout
  title="Hotel | Díaz Servicios SRL - Hospedaje en Ingeniero Juárez"
  description="Reservá tu estadía en el hotel de Díaz Servicios SRL en Ingeniero Juárez, Formosa. Habitaciones confortables, descuentos para socios ACA y atención personalizada. Consultá disponibilidad por WhatsApp."
>
  <Header />
  <main>
    <!-- Hero hotel -->
    <section class="hotel-hero">
      <div class="hotel-hero__media" aria-hidden="true">
        <img src="/images/fachada-ypf.jpg" alt="" loading="eager" />
        <div class="hotel-hero__overlay"></div>
      </div>
      <div class="container hotel-hero__content">
        <span class="eyebrow reveal">Hospedaje</span>
        <h1 class="hotel-hero__title reveal reveal-delay-1">
          Descansá en Ingeniero Juárez con toda la comodidad
        </h1>
        <p class="hotel-hero__subtitle reveal reveal-delay-2">
          Habitaciones cómodas y seguras para viajeros que necesitan una pausa
          antes de seguir camino. Con descuentos especiales para socios ACA.
        </p>
        <a href="#reserva" class="btn btn-primary reveal reveal-delay-3">
          Consultar disponibilidad
        </a>
      </div>
    </section>

    <!-- Características -->
    <section class="section-light hotel-features">
      <div class="container">
        <div class="grid hotel-features__grid">
          {
            features.map((f, i) => (
              <div
                class={`hotel-features__item reveal reveal-delay-${(i % 3) + 1}`}
              >
                <span class="hotel-features__icon" aria-hidden="true">
                  {f.icon}
                </span>
                <span>{f.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Sección reserva -->
    <section id="reserva" class="section-muted hotel-booking">
      <div class="container hotel-booking__grid">
        <div class="hotel-booking__info reveal">
          <span class="eyebrow">Reservas</span>
          <h2 class="section-title">Consultá disponibilidad en minutos</h2>
          <p class="hotel-booking__lead">
            Completá el formulario con los datos de tu estadía y te respondemos
            por WhatsApp a la brevedad con disponibilidad y precios. Si sos
            socio ACA, indicalo para acceder a la tarifa especial.
          </p>
          <div
            class="hotel-carousel"
            id="hotel-carousel"
            role="region"
            aria-label="Fotos del hotel"
          >
            <div class="hotel-carousel__track" id="hotel-carousel-track">
              {
                carouselSlides.map((slide) => (
                  <div class="hotel-carousel__slide">
                    <img src={slide.src} alt={slide.alt} loading="lazy" />
                  </div>
                ))
              }
            </div>

            <button
              class="hotel-carousel__btn hotel-carousel__btn--prev"
              id="carousel-prev"
              aria-label="Foto anterior"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m15 18-6-6 6-6"></path>
              </svg>
            </button>
            <button
              class="hotel-carousel__btn hotel-carousel__btn--next"
              id="carousel-next"
              aria-label="Foto siguiente"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m9 18 6-6-6-6"></path>
              </svg>
            </button>

            <div class="hotel-carousel__dots" id="carousel-dots">
              {
                carouselSlides.map((_, i) => (
                  <button
                    class={`hotel-carousel__dot${i === 0 ? " is-active" : ""}`}
                    aria-label={`Foto ${i + 1}`}
                    data-index={String(i)}
                  />
                ))
              }
            </div>
          </div>
        </div>

        <div class="hotel-booking__form-wrap reveal reveal-delay-1">
          <form id="hotel-form" class="hotel-form" novalidate>
            <h3 class="hotel-form__title">Datos de tu estadía</h3>

            <div class="hotel-form__row">
              <div class="form-group">
                <label for="checkin">Fecha de ingreso</label>
                <input
                  type="date"
                  id="checkin"
                  name="checkin"
                  class="form-control"
                  required
                />
              </div>
              <div class="form-group">
                <label for="checkout">Fecha de egreso</label>
                <input
                  type="date"
                  id="checkout"
                  name="checkout"
                  class="form-control"
                  required
                />
              </div>
            </div>

            <div class="form-group">
              <label for="guests">Cantidad de personas</label>
              <div class="guests-control">
                <button
                  type="button"
                  class="guests-btn"
                  id="guests-dec"
                  aria-label="Menos personas">−</button
                >
                <output
                  id="guests-display"
                  class="guests-display"
                  aria-live="polite">1</output
                >
                <input type="hidden" id="guests" name="guests" value="1" />
                <button
                  type="button"
                  class="guests-btn"
                  id="guests-inc"
                  aria-label="Más personas">+</button
                >
              </div>
            </div>

            <div class="form-group">
              <label>¿Sos socio ACA?</label>
              <div class="radio-group">
                <label class="radio-card">
                  <input
                    type="radio"
                    name="aca"
                    value="Sí, soy socio ACA"
                    required
                  />
                  <span class="radio-card__inner">
                    <span class="radio-card__icon" aria-hidden="true">🎫</span>
                    <span>Sí, soy socio</span>
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="aca" value="No soy socio ACA" />
                  <span class="radio-card__inner">
                    <span class="radio-card__icon" aria-hidden="true">👤</span>
                    <span>No soy socio</span>
                  </span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label>Tipo de cama</label>
              <div class="radio-group">
                <label class="radio-card">
                  <input
                    type="radio"
                    name="room"
                    value="Cama matrimonial"
                    required
                  />
                  <span class="radio-card__inner">
                    <span class="radio-card__icon" aria-hidden="true">🛏️</span>
                    <span>Matrimonial</span>
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="room" value="Camas separadas" />
                  <span class="radio-card__inner">
                    <span class="radio-card__icon" aria-hidden="true">🛏🛏</span
                    >
                    <span>Separadas</span>
                  </span>
                </label>
              </div>
            </div>

            <p
              id="hotel-form-error"
              class="hotel-form__error"
              role="alert"
              aria-live="assertive"
            >
            </p>

            <button type="submit" class="btn btn-whatsapp hotel-form__submit">
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                width="20"
                height="20"
              >
                <path
                  d="M12 3a9 9 0 0 0-7.8 13.4L3 21l4.7-1.2A9 9 0 1 0 12 3Zm0 16.3a7.3 7.3 0 0 1-3.9-1.1l-.3-.2-2.8.7.8-2.7-.2-.3A7.3 7.3 0 1 1 12 19.3Zm4-5.3c-.2-.1-1.3-.6-1.5-.7-.2-.1-.3-.1-.5.1l-.6.8c-.1.1-.2.1-.4 0a5.5 5.5 0 0 1-1.6-1 6 6 0 0 1-1.1-1.4c-.1-.2 0-.3.1-.4l.4-.4.2-.4v-.4l-.7-1.6c-.2-.4-.4-.4-.5-.4h-.4c-.2 0-.4.1-.6.3a2.9 2.9 0 0 0-.9 2.2c0 1.3.9 2.5 1 2.7a8.7 8.7 0 0 0 3.8 3.3c1.8.7 1.8.5 2.1.4.4 0 1.3-.5 1.5-1 .2-.5.2-.9.1-1Z"
                ></path>
              </svg>
              Enviar consulta por WhatsApp
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .hotel-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--header-height) + 2.5rem);
    padding-bottom: 3.5rem;
    overflow: hidden;
    color: var(--color-white);
  }

  .hotel-hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      135deg,
      var(--color-aca-blue) 0%,
      var(--color-aca-blue-dark) 60%,
      var(--color-black) 100%
    );
  }

  .hotel-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
    mix-blend-mode: luminosity;
  }

  .hotel-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(7, 51, 94, 0.6) 0%,
      rgba(7, 51, 94, 0.88) 100%
    );
  }

  .hotel-hero__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hotel-hero .eyebrow {
    color: var(--color-ypf-yellow);
    margin-bottom: 1rem;
  }

  .hotel-hero__title {
    font-size: clamp(2.2rem, 5.5vw, 3.5rem);
    margin-bottom: 1.1rem;
  }

  .hotel-hero__subtitle {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2.25rem;
  }

  /* ── Features strip ── */
  .hotel-features__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .hotel-features__item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.25rem;
    background: var(--color-gray-light);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-gray-dark);
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .hotel-features__item:hover {
    background-color: var(--color-aca-blue);
    color: var(--color-white);
  }

  .hotel-features__icon {
    font-size: 1.1rem;
  }

  /* ── Booking layout ── */
  .hotel-booking__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .hotel-booking__lead {
    color: var(--color-gray-dark);
    margin-block: 1.25rem 1.75rem;
    font-size: 1.02rem;
  }

  /* ── Carousel ── */
  .hotel-carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-strong);
    margin-top: 1.75rem;
  }

  @media (min-width: 880px) {
    .hotel-booking__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hotel-carousel {
      margin-top: 0;
    }
  }

  .hotel-carousel__track {
    display: flex;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .hotel-carousel__slide {
    flex: 0 0 100%;
    height: 100%;
  }

  .hotel-carousel__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hotel-carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 38px;
    height: 38px;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.88);
    color: var(--color-aca-blue-dark);
    cursor: pointer;
    display: grid;
    place-items: center;
    box-shadow: var(--shadow-soft);
    transition: background-color 0.2s;
  }

  .hotel-carousel__btn:hover {
    background-color: var(--color-white);
  }

  .hotel-carousel__btn svg {
    width: 17px;
    height: 17px;
  }

  .hotel-carousel__btn--prev {
    left: 0.65rem;
  }
  .hotel-carousel__btn--next {
    right: 0.65rem;
  }

  .hotel-carousel__dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.45rem;
    z-index: 2;
  }

  .hotel-carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition:
      background-color 0.2s,
      transform 0.2s;
  }

  .hotel-carousel__dot.is-active {
    background: var(--color-white);
    transform: scale(1.35);
  }

  /* ── Form card ── */
  .hotel-booking__form-wrap {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-strong);
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }

  .hotel-form__title {
    font-size: 1.35rem;
    color: var(--color-aca-blue-dark);
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-gray-light);
  }

  /* ── Form elements ── */
  .form-group {
    margin-bottom: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-aca-blue-dark);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-control {
    padding: 0.8rem 1rem;
    border: 1.5px solid #d1d9e0;
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 0.97rem;
    color: var(--color-black);
    background-color: var(--color-white);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-control:focus {
    outline: none;
    border-color: var(--color-aca-blue);
    box-shadow: 0 0 0 3px rgba(10, 79, 158, 0.12);
  }

  /* Date row */
  .hotel-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 480px) {
    .hotel-form__row {
      grid-template-columns: 1fr;
    }
  }

  /* Guests counter */
  .guests-control {
    display: flex;
    align-items: center;
    gap: 0;
    width: fit-content;
    border: 1.5px solid #d1d9e0;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .guests-btn {
    width: 46px;
    height: 46px;
    border: none;
    background: var(--color-gray-light);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-aca-blue-dark);
    cursor: pointer;
    transition: background-color 0.2s;
    flex-shrink: 0;
  }

  .guests-btn:hover {
    background-color: var(--color-aca-blue);
    color: var(--color-white);
  }

  .guests-display {
    min-width: 70px;
    text-align: center;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-aca-blue-dark);
    padding: 0 0.5rem;
  }

  /* Radio cards */
  .radio-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .radio-card {
    cursor: pointer;
  }

  .radio-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .radio-card__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1rem 0.75rem;
    border: 1.5px solid #d1d9e0;
    border-radius: var(--radius-md);
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-gray-dark);
    transition:
      border-color 0.2s,
      background-color 0.2s,
      color 0.2s;
  }

  .radio-card:hover .radio-card__inner {
    border-color: var(--color-aca-blue);
  }

  .radio-card input[type="radio"]:checked + .radio-card__inner {
    border-color: var(--color-aca-blue);
    background-color: rgba(10, 79, 158, 0.06);
    color: var(--color-aca-blue-dark);
  }

  .radio-card__icon {
    font-size: 1.4rem;
  }

  /* Error message */
  .hotel-form__error {
    color: #c0392b;
    font-size: 0.88rem;
    font-weight: 600;
    min-height: 1.2rem;
    margin-bottom: 0.5rem;
  }

  /* Submit */
  .hotel-form__submit {
    width: 100%;
    font-size: 1rem;
    padding: 1rem 1.5rem;
    gap: 0.6rem;
  }
</style>

<script>
  const AUTOPLAY_MS = 4000;

  function initCarousel() {
    const carousel = document.getElementById("hotel-carousel");
    const track = document.getElementById(
      "hotel-carousel-track",
    ) as HTMLElement | null;
    const dots = document.querySelectorAll<HTMLButtonElement>(
      ".hotel-carousel__dot",
    );
    const total = dots.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    if (!track || total === 0) return;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track!.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle("is-active", i === current));
    }

    function startAutoplay() {
      timer = setInterval(() => goTo(current + 1), AUTOPLAY_MS);
    }

    function stopAutoplay() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }

    function resetAutoplay() {
      stopAutoplay();
      startAutoplay();
    }

    document.getElementById("carousel-prev")?.addEventListener("click", () => {
      goTo(current - 1);
      resetAutoplay();
    });
    document.getElementById("carousel-next")?.addEventListener("click", () => {
      goTo(current + 1);
      resetAutoplay();
    });
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        goTo(Number(dot.dataset.index));
        resetAutoplay();
      });
    });

    // Pausar al pasar el mouse por encima
    carousel?.addEventListener("mouseenter", stopAutoplay);
    carousel?.addEventListener("mouseleave", startAutoplay);

    startAutoplay();

    // Limpiar al salir de la página (View Transitions)
    document.addEventListener("astro:before-swap", stopAutoplay, {
      once: true,
    });
  }

  document.addEventListener("astro:page-load", initCarousel);
</script>

<script define:vars={{ HOTEL_WHATSAPP_NUMBER }}>
  const form = document.getElementById("hotel-form");
  const guestsInput = document.getElementById("guests");
  const guestsDisplay = document.getElementById("guests-display");
  const guestsDec = document.getElementById("guests-dec");
  const guestsInc = document.getElementById("guests-inc");
  const errorEl = document.getElementById("hotel-form-error");

  let guests = 1;

  function updateGuests(delta) {
    guests = Math.max(1, Math.min(20, guests + delta));
    guestsInput.value = String(guests);
    guestsDisplay.textContent = String(guests);
  }

  guestsDec?.addEventListener("click", () => updateGuests(-1));
  guestsInc?.addEventListener("click", () => updateGuests(1));

  function formatDate(raw) {
    if (!raw) return "(sin fecha)";
    const [y, m, d] = raw.split("-");
    return `${d}/${m}/${y}`;
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    errorEl.textContent = "";

    const data = new FormData(form);
    const checkin = data.get("checkin");
    const checkout = data.get("checkout");
    const guestsVal = data.get("guests");
    const aca = data.get("aca");
    const room = data.get("room");

    if (!checkin) {
      errorEl.textContent = "Por favor indicá la fecha de ingreso.";
      return;
    }
    if (!checkout) {
      errorEl.textContent = "Por favor indicá la fecha de egreso.";
      return;
    }
    if (new Date(checkout) <= new Date(checkin)) {
      errorEl.textContent =
        "La fecha de egreso debe ser posterior a la de ingreso.";
      return;
    }
    if (!aca) {
      errorEl.textContent = "Por favor indicá si sos socio ACA.";
      return;
    }
    if (!room) {
      errorEl.textContent = "Por favor seleccioná el tipo de cama.";
      return;
    }

    const nights = Math.round(
      (new Date(checkout) - new Date(checkin)) / 86400000,
    );
    const nightLabel = nights === 1 ? "1 noche" : `${nights} noches`;
    const guestLabel =
      guestsVal === "1" ? "1 persona" : `${guestsVal} personas`;

    const message =
      `¡Hola! Quisiera consultar disponibilidad en el Hotel de Díaz Servicios SRL.\n\n` +
      `📅 Ingreso: ${formatDate(checkin)}\n` +
      `📅 Egreso: ${formatDate(checkout)} (${nightLabel})\n` +
      `👥 Personas: ${guestLabel}\n` +
      `🎫 Socio ACA: ${aca}\n` +
      `🛏️ Tipo de cama: ${room}\n\n` +
      `Espero su respuesta. ¡Muchas gracias!`;

    window.open(
      `https://wa.me/${HOTEL_WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`,
      "_blank",
      "noopener,noreferrer",
    );
  });
</script>
